# App
APP_PORT=8001
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Gemini
GEMINI_API_KEY=AIzaSy...
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4096

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=iccp-knowledge
PINECONE_ENVIRONMENT=us-east-1-aws

# MongoDB
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=iccp_ai
MONGODB_EXPOSE_PORT=27018

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Internal communication with iccp_be_core
BE_CORE_BASE_URL=http://iccp-be-core:3333
INTERNAL_API_KEY=super-secret-internal-key
BE_CORE_INTROSPECT_URL=http://iccp-be-core:3333/api/v1/auth/introspect

# RAG tuning
CHUNK_SIZE=384
CHUNK_OVERLAP=96
RETRIEVAL_TOP_K=8

# Feature flags
ENABLE_RERANKING=false
# Set true to improve Vietnamese <-> English cross-language retrieval recall.
ENABLE_QUERY_EXPANSION=false
ENABLE_ANALYTICS_AGENT=true
